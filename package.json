{
  "name": "opsucht-wirtschaftsdashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Inoffizielles Wirtschafts- und Analyse-Dashboard für die öffentlichen OPSUCHT-APIs.",
  "scripts": {
    "dev": "vite",
    "build": "vinext build",
    "start": "node dist/standalone/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:next": "next dev",
    "build:next": "next build",
    "start:next": "next start",
    "dev:vinext": "vinext dev --port 3001",
    "build:vinext": "vinext build",
    "start:vinext": "vinext start"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "overrides": {
    "postcss": "8.5.20"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.3",
    "@tanstack/react-table": "8.21.3",
    "date-fns": "4.4.0",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "3.9.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "24.10.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-rsc": "^0.5.28",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "react-server-dom-webpack": "^19.2.7",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vinext": "^0.0.50",
    "vite": "^8.1.5",
    "vitest": "4.1.10",
    "wrangler": "^4.112.0"
  }
}
